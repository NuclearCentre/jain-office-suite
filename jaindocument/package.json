{
  "name": "jaindocument",
  "version": "1.1.0",
  "description": "JainDocument",
  "author": "JainDocument",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.jaindocument.app",
    "productName": "JainDocument",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "NuclearCentre",
        "repo": "wordpad-pro-releases",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JainDocument",
      "artifactName": "JainDocument Setup ${version}.exe",
      "differentialPackage": false,
      "installerSidebar": "build/sidebar.bmp",
      "include": "build/installer.nsh"
    },
    "fileAssociations": [
      {
        "ext": "wpdoc",
        "name": "JainDocument Document",
        "description": "JainDocument Document",
        "icon": "assets/icon.ico",
        "role": "Editor"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/docx/**/*",
      "node_modules/mammoth/**/*",
      "node_modules/jsdom/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*"
    ]
  },
  "devDependencies": {
    "electron": "28.0.0",
    "electron-builder": "24.9.1"
  },
  "dependencies": {
    "docx": "8.5.0",
    "mammoth": "1.7.2",
    "jsdom": "24.0.0",
    "electron-updater": "6.1.7"
  }
}
