{
  "name": "jain-office-suite",
  "version": "1.0.0",
  "description": "Jain Office Suite — One installer for JainDocument and JainSheet",
  "author": "Jain Office Suite",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-updater": "6.1.7"
  },
  "devDependencies": {
    "electron": "28.0.0",
    "electron-builder": "24.9.1"
  },
  "build": {
    "appId": "com.jainoffice.app",
    "productName": "Jain Office Suite",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../jaindocument",
        "to": "jaindocument",
        "filter": ["**/*", "!node_modules/.cache/**/*"]
      },
      {
        "from": "../jainsheet",
        "to": "jainsheet",
        "filter": ["**/*", "!node_modules/.cache/**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Jain Office Suite",
      "differentialPackage": false,
      "include": "installer.nsh",
      "installerSidebar": "suite_sidebar.bmp"
    },
    "fileAssociations": [
      {
        "ext": "docx",
        "name": "Word Document",
        "description": "Microsoft Word Document",
        "icon": "assets/icon.ico",
        "role": "Editor"
      },
      {
        "ext": "doc",
        "name": "Word Document",
        "description": "Microsoft Word 97-2003 Document",
        "icon": "assets/icon.ico",
        "role": "Editor"
      },
      {
        "ext": "xlsx",
        "name": "Excel Spreadsheet",
        "description": "Microsoft Excel Spreadsheet",
        "icon": "assets/icon.ico",
        "role": "Editor"
      },
      {
        "ext": "xls",
        "name": "Excel Spreadsheet",
        "description": "Microsoft Excel 97-2003 Spreadsheet",
        "icon": "assets/icon.ico",
        "role": "Editor"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "installer.nsh",
      "assets/**/*"
    ]
  }
}
