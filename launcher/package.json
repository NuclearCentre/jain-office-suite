{
  "name": "jain-office-suite",
  "version": "1.0.0",
  "description": "Jain Office Suite — Launcher",
  "author": "Jain Office Suite",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.jainoffice.app",
    "productName": "Jain Office Suite",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "NuclearCentre",
        "repo": "jain-office-suite",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Jain Office",
      "artifactName": "Jain Office Suite Setup ${version}.exe",
      "differentialPackage": false
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "assets/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "24.9.1"
  },
  "dependencies": {
    "electron-updater": "6.1.7"
  }
}
